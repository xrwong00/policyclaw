# PolicyClaw backend environment — copy to backend/.env and fill GLM_API_KEY.
# Without GLM_API_KEY the backend runs in deterministic mock mode; the flow
# still works end-to-end but outputs are synthetic.

# Required — your Ilmu GLM (Z.AI authorized endpoint) API key
GLM_API_KEY=your_ilmu_api_key_here

# Optional — defaults shown; override only if Ilmu moves the endpoint or you
# pin to a different GLM revision approved by the hackathon organizers.
GLM_API_BASE=https://api.ilmu.ai/v1
GLM_MODEL=ilmu-glm-5.1

# Optional — extra verbose logging in FastAPI.
DEBUG=false
