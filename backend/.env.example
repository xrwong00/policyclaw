# PolicyClaw backend environment — copy to backend/.env and fill OPENAI_API_KEY.
# Without OPENAI_API_KEY the backend runs in deterministic mock mode; the flow
# still works end-to-end but outputs are synthetic.

# Required — your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional — defaults shown; override only if you're pointing at a compatible
# proxy or pinning to a different model revision.
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

# Optional — extra verbose logging in FastAPI.
DEBUG=false
